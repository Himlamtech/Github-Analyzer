{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "grafana-clickhouse-datasource", "name": "ClickHouse", "version": "4.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Demo-focused observability dashboard for the seminar narrative: the API is alive, but the business flow is stale.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "Open Grafana Explore",
      "type": "link",
      "url": "http://localhost:3001/explore"
    },
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "Open API Docs",
      "type": "link",
      "url": "http://localhost:8000/docs"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Executive Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "text": "Down" }, "1": { "text": "Up" } }, "type": "value" }
          ],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "id": 10,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        { "expr": "up{job=\"github_analyzer_api\"}", "legendFormat": "API", "refId": "A" }
      ],
      "title": "API Availability",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "text": "Stopped" }, "1": { "text": "Running" } }, "type": "value" }
          ],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "id": 11,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        { "expr": "up{job=\"github_analyzer_processor\"}", "legendFormat": "Processor", "refId": "A" }
      ],
      "title": "Processor Health",
      "type": "stat"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 180 },
              { "color": "red", "value": 300 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "id": 12,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_ds" },
          "format": 0,
          "queryType": "table",
          "rawSql": "SELECT dateDiff('second', max(created_at), now()) AS value FROM github_analyzer.github_data",
          "refId": "A"
        }
      ],
      "title": "Data Freshness",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.01 },
              { "color": "green", "value": 0.1 }
            ]
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "id": 13,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(rate(spark_records_processed_total{job=\"github_analyzer_processor\"}[5m]))",
          "legendFormat": "Records / s",
          "refId": "A"
        }
      ],
      "title": "Pipeline Throughput",
      "type": "stat"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 180 },
              { "color": "red", "value": 300 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "id": 14,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_ds" },
          "format": 0,
          "queryType": "table",
          "rawSql": "SELECT dateDiff('second', max(created_at), now()) AS value FROM github_analyzer.github_data",
          "refId": "A"
        }
      ],
      "title": "Latest Successful Write Age",
      "type": "stat"
    },
    {
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "id": 15,
      "options": {
        "content": "### Demo claim\n- API can stay **Up**\n- Processor can stop\n- Freshness keeps rising\n- Business value stops flowing",
        "mode": "markdown"
      },
      "title": "Incident Narrative",
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 2,
      "title": "Request Signals",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 7 },
      "id": 20,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total{job=\"github_analyzer_api\",route!=\"/health\"}[5m]))",
          "legendFormat": "All business routes",
          "refId": "A"
        },
        {
          "expr": "sum by (route) (rate(api_requests_total{job=\"github_analyzer_api\",route!=\"/health\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "B"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 7 },
      "id": 21,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(api_request_duration_seconds_bucket{job=\"github_analyzer_api\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket{job=\"github_analyzer_api\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(api_request_duration_seconds_bucket{job=\"github_analyzer_api\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Request Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "min": 0,
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 7 },
      "id": 22,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum(rate(api_requests_total{job=\"github_analyzer_api\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(api_requests_total{job=\"github_analyzer_api\"}[5m])), 0.001)",
          "legendFormat": "5xx rate",
          "refId": "A"
        },
        {
          "expr": "api_in_flight_requests{job=\"github_analyzer_api\"}",
          "legendFormat": "In-flight requests",
          "refId": "B"
        }
      ],
      "title": "Errors And Concurrency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 3,
      "title": "Business Flow",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 30,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum(rate(events_ingested_total{job=\"github_analyzer_poller\"}[5m]))",
          "legendFormat": "Events ingested",
          "refId": "A"
        },
        {
          "expr": "sum(rate(kafka_messages_produced_total{job=\"github_analyzer_poller\"}[5m]))",
          "legendFormat": "Kafka produced",
          "refId": "B"
        },
        {
          "expr": "sum(rate(spark_records_processed_total{job=\"github_analyzer_processor\",sink=\"clickhouse\"}[5m]))",
          "legendFormat": "Spark -> ClickHouse",
          "refId": "C"
        }
      ],
      "title": "End-to-End Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "id": 31,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "max(data_freshness_seconds{job=\"github_analyzer_api\"})",
          "legendFormat": "API freshness signal",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(poll_cycle_duration_seconds_bucket{job=\"github_analyzer_poller\"}[5m])) by (le))",
          "legendFormat": "Poll cycle p95",
          "refId": "B"
        }
      ],
      "title": "Freshness And Polling Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_ds" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {},
          "unit": "dateTimeAsIso"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 32,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse_ds" },
          "format": 0,
          "queryType": "table",
          "rawSql": "SELECT toUnixTimestamp(max(created_at)) * 1000 AS value FROM github_analyzer.github_data",
          "refId": "A"
        }
      ],
      "title": "Latest Event Timestamp",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 4,
      "title": "Tracing And Correlation",
      "type": "row"
    },
    {
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 25 },
      "id": 40,
      "options": {
        "content": "### Demo drilldown\n1. Call `GET /pipeline/status`\n2. Copy `X-Trace-Id` or open `X-Trace-Explore-Url`\n3. Verify the API request still completes\n4. Correlate that healthy request with stale freshness on the panels above\n\nThis is the seminar claim: **healthy does not mean correct**.",
        "mode": "markdown"
      },
      "title": "Trace Workflow",
      "type": "text"
    },
    {
      "datasource": { "type": "loki", "uid": "loki_ds" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 25 },
      "id": 41,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{compose_service=\"api\"} |= \"api.request.completed\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "API Request Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki_ds" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 25 },
      "id": 42,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{compose_service=~\"poller|processor\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Pipeline Logs",
      "type": "logs"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["demo", "observability", "tracing", "seminar", "root-cause"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "GHA Observability Demo",
  "uid": "gha-observability-demo",
  "version": 1,
  "weekStart": ""
}
