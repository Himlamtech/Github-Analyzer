            "title": "Table Storage & Row Counts",
            "type": "table",
            "targets": [
                {
                    "datasource": {
                        "type": "grafana-clickhouse-datasource",
                        "uid": "clickhouse_ds"
                    },
                    "rawSql": "SELECT table as Table, sum(rows) as Rows, formatReadableSize(sum(data_compressed_bytes)) as \"Compressed (MB)\", formatReadableSize(sum(data_uncompressed_bytes)) as \"Uncompressed\", round(sum(data_compressed_bytes) / greatest(sum(data_uncompressed_bytes), 1) * 100, 1) as \"Compression %\" FROM system.parts WHERE database = 'github_analyzer' AND active = 1 GROUP BY table ORDER BY sum(data_compressed_bytes) DESC",
                    "queryType": "table",
                    "format": 0,
                    "refId": "A"
