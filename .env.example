# ============================================================
# GitHub AI Trend Analyzer — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ---- GitHub API ----
# Comma-separated personal access tokens (classic or fine-grained)
# Minimum scope: public_repo (read-only)
# More tokens = higher effective rate limit (5,000 req/hr per token)
GITHUB_API_TOKENS=ghp_token1,ghp_token2,ghp_token3

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=github_raw_events
KAFKA_RETENTION_HOURS=168

# ---- ClickHouse ----
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9100
CLICKHOUSE_USER=github_analyzer
CLICKHOUSE_PASSWORD=github_analyzer
CLICKHOUSE_DATABASE=github_analyzer

# ---- Storage paths ----
PARQUET_BASE_PATH=./data/raw
CHECKPOINT_BASE_PATH=./data/checkpoints
REPO_METADATA_PATH=./data/repos

# ---- AI / Retrieval ----
OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_EMBEDDING_MODEL=qwen3-embedding-0.6b
OLLAMA_GENERATION_MODEL=llama3.2:3b
YESCALE_API_KEY=your_yescale_api_key_here
YESCALE_BASE_URL=https://api.yescale.io/v1beta
YESCALE_GENERATION_MODEL=gemini-3.1-flash-lite-preview
SEARXNG_BASE_URL=http://localhost:8080
SEARXNG_TIMEOUT_SECONDS=10
SEARXNG_NEWS_LIMIT=3

# ---- Spark ----
SPARK_MASTER=local[16]
SPARK_DRIVER_MEMORY=8g
SPARK_EXECUTOR_MEMORY=12g

# ---- Observability ----
METRICS_PORT=9091
TEMPO_PORT=3200
TRACING_ENABLED=true
TRACING_SAMPLING_RATIO=1.0
TRACING_SERVICE_NAME=gha-api
TRACING_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
TRACING_GRAFANA_BASE_URL=http://localhost:3001
TRACING_GRAFANA_ORG_ID=1
TRACING_GRAFANA_TEMPO_DATASOURCE_UID=tempo_ds
TRACING_GRAFANA_EXPLORE_FROM=now-1h
TRACING_GRAFANA_EXPLORE_TO=now
LOG_LEVEL=INFO

# ---- Security (Grafana) ----
GRAFANA_PASSWORD=github_analyzer
