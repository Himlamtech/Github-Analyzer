LOG_LEVEL=INFO

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=github_analyzer

PARQUET_BASE_PATH=/app/data/raw
CHECKPOINT_BASE_PATH=/app/data/checkpoints
REPO_CATALOG_PATH=/app/data/catalog/repos.json
REPO_METADATA_PATH=/app/data/catalog/repo_metadata.json

GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_TOKENS=
REPO_DISCOVERY_START_DATE=2026-01-01
REPO_DISCOVERY_MIN_STARS=1000
REPO_DISCOVERY_MAX_SHARD_SIZE=100

AI_SEARCH_SEMANTIC_ENABLED=true
AI_SEARCH_CANDIDATE_LIMIT=50
AI_SEARCH_DEFAULT_LIMIT=10
AI_SEARCH_EMBEDDING_TIMEOUT_SECONDS=30
AI_REPO_BRIEF_LLM_ENABLED=true
AI_MARKET_BRIEF_LLM_ENABLED=true
AI_REPO_BRIEF_TIMEOUT_SECONDS=60

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_GENERATION_MODEL=llama3.1

TRACING_ENABLED=true
TRACING_SERVICE_NAME=github-ai-analyzer-api
TRACING_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
TRACING_SAMPLING_RATIO=1.0

GRAFANA_PASSWORD=admin

